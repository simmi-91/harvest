{
  "name": "harvest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:migrate": "psql $DATABASE_URL -f scripts/init.sql",
    "db:seed": "psql $DATABASE_URL -f scripts/seed.sql",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit",
    "gemini:list-models": "npx tsx --env-file=.env.local scripts/check-gemini-models.mts",
    "sandcastle": "npx tsx --env-file=.sandcastle/.env .sandcastle/main.mts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "next": "^16.2.5",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.5.10",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.11.13",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^29.7.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
